<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- ══ HEADER ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1e1e1e"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tabs"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Close All Button -->
        <android.widget.Button
            android:id="@+id/btn_close_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close All"
            android:textColor="#ff6b6b"
            android:textSize="13sp"
            android:background="@null"
            android:padding="8dp"/>

        <!-- Done Button -->
        <android.widget.Button
            android:id="@+id/btn_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textColor="#2979ff"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@null"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- ══ TAB TYPE SELECTOR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#181818"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tab_normal_label"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Normal"
            android:gravity="center"
            android:textColor="#2979ff"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="#1e1e1e"/>

        <TextView
            android:id="@+id/tab_private_label"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="🕵️ Private"
            android:gravity="center"
            android:textColor="#888888"
            android:textSize="13sp"
            android:background="#181818"/>

    </LinearLayout>

    <!-- ══ TAB GRID ══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tab_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- ══ BOTTOM ACTION BAR ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1e1e1e"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp">

        <!-- New Normal Tab -->
        <LinearLayout
            android:id="@+id/btn_new_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_add"
                android:tint="#2979ff"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Tab"
                android:textColor="#2979ff"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- New Private Tab -->
        <LinearLayout
            android:id="@+id/btn_new_private_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_private"
                android:tint="#9c27b0"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Private"
                android:textColor="#9c27b0"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
